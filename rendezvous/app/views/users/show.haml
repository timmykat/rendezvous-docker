.container
  .row.justify-content-center
    .col-md-10.col-12
      .card 
        .card-body 
          .card-title
            - if user_is_admin?
              %h1.h2 Profile for #{@user.full_name}
            - else
              %h1.h2 Your Info

      .card
        .card-body
          .card-text
            - if user_is_admin?
              %h2 Profile Information for #{@user.last_name_first}
            .profile-info
              .user-info
                %h3.h4 The Basics
                %table
                  %tr
                    %td
                      %em Name: 
                      #{@user.full_name}
                  %tr
                    %td
                      %em Email: 
                      #{@user.email}
                  %tr
                    %td
                      %em Address:
                      %br
                      %blockquote
                        = address_of(@user)
            .card-text
              %h3.h4 Registration Status
              %p
                Status: #{registration_status}

              - if registration_status != 'Complete'
                %p To register or finish a registration: 
                %ul 
                  - if @current_registration
                    %li= link_to 'Continue to current registration', review_event_registration_path(@current_registration)
                  - else
                    %li= link_to 'Create a registration',  new_event_registration_path 

              .vehicle-info.mt-6
                %h3.h4 Vehicles
                - if @user.vehicles.blank?
                  %p Currently no vehicles registered.
                  %p
                    = link_to 'Add a vehicle', edit_user_path(@user), class: 'btn btn-primary'
                - else
                  %table.table
                    %tbody
                    - @user.vehicles.each do |v|
                      %tr
                        %td{colspan: 2}
                          %hr
                      %tr
                        %td 
                          %em Year, marque & model:
                        %td= v.year_marque_model
                      %tr
                        %td 
                          %em Judging category:
                        %td= v.judging_category
                      %tr
                        %td.mr-3 
                          %em Bringing to the Rendezvous?
                        %td= v.bringing ? 'Yes' : 'No'
                      %tr
                        %td 
                          %em For sale?
                        %td= v.for_sale ? 'Yes' : 'No'


            =link_to 'Edit my information', edit_user_path(@user), class:  "btn  btn-warning mt-3" 
      
      .card
        .card-body
          .card-text

            %ul
              %li 
                %em Recorded Rendezvous attendance: #{attended_rendezvous_years(@user)}
              %li 
                %em Registered for the #{Date.current.year} Rendezvous: #{@user.attending ? 'Yes' : 'No'}
              %li
                %em Interested in Citroenvie: #{@user.citroenvie? ? 'Yes' : 'No'}

    
