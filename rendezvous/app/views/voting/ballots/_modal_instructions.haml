.modal{tabindex: "-1", id: "voting-instructions"}
  .modal-dialog.modal-dialog-centered
    .modal-content
      .modal-header
        %h2.h4 INSTRUCTIONS
        %button.btn-close.ml-auto{"aria-label" => "Close", "data-dismiss" => "modal", type: "button"} #{icon(:close, size: '20', color: 'black')}
      .modal-body
        %ul
          %li.mb-3
            Vote by aiming your camera at the QR code on the dash placard to get the ID.
          %li.mb-3 OR
          %li.mb-3
            Select the Vote tab and enter the car ID from the dash card yourself.
          %li.mb-3
          %li.mb-3 THEN
          %li.mb-3 the details for the selected vehicle will appear and the vote button will become active.
          %li.mb-3 Click the Vote button to register your vote.
