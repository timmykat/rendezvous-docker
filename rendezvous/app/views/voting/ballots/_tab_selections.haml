.tab-content{ data: { tab_content: 'selections' } }
  .card
    .card-body
      .card-title
        %h3.h5.d-flex.justify-content-between.align-items-center Ballot Choices
  .selections
    - selections.each do |category, vehicles|
      .category.alert.alert-warning
        .category-name.d-flex.justify-content-between
          %strong #{category}
          -if vehicles.nil? || vehicles.length == 0
            .badge.badge-warning.ml-5 No selections
          -# - elsif vehicles.length >= 1
          -#   .badge.badge-warning.ml-5 Limit reached
        - unless vehicles.nil?
          .selected-vehicle
            %ul.vehicles.list-unstyled
              - vehicles.each do |v|
                %li.alert.alert-info.d-flex.align-items-center.justify-content-between.px-2
                  .vehicle
                    #{v.year_marque_model} | #{v.user.full_name}
                    %br (code: #{v.qr_code.code})
                  = form_with url: delete_selection_voting_ballot_path(id: @ballot.id, vehicle_id: v.id), method: :delete, data: { turbo: false }  do |f|
                    = f.button type: :submit, class: 'btn', data: { toggle: 'modal', target: '#transition-modal' } do
                      = icon(:delete, size: '24')
