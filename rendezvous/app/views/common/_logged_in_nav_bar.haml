.container-fluid.px-0
  .row.no-gutters.bg-nav
    .col-12
      .container
        .row
          .col-12
            %nav.nav.navbar.navbar-dark.navbar-expand-lg.bg-nav
              %button.navbar-toggler{ type: 'button', 'data-toggle' => 'collapse', 'data-target' => '#navbarContent' }
                %span.navbar-toggler-icon

              .collapse.navbar-collapse#navbarContent
                %ul.nav.navbar-nav
                  %li.nav-item= link_to 'Home', root_path, class: 'nav-link'
                  %li.nav-item= link_to 'Schedule Overview', "#{root_path}#schedule-overview", class: 'nav-link'
                  %li.nav-item= link_to 'Schedule Summary', schedule_summary_path, class: 'nav-link'
                  %li.nav-item= link_to 'Vendors', vendors_path, class: 'nav-link'
                  %li.nav-item= link_to 'Volunteering', volunteering_path, class: 'nav-link'
                  - if vehicles_for_sale > 0
                    %li.nav-item= link_to "For Sale (#{vehicles_for_sale})", vehicles_for_sale_path, class: 'nav-link'

                / Right-aligned section
                %ul.nav.navbar-nav.ml-auto
                  %li.nav-item.dropdown
                    %a.nav-link.dropdown-toggle#userDropdown{
                      href: '#',
                      role: 'button',
                      'data-toggle' => 'dropdown',
                      'aria-haspopup' => 'true',
                      'aria-expanded' => 'false'
                    }
                      = current_user.full_name

                    .dropdown-menu.dropdown-menu-right{ 'aria-labelledby' => 'userDropdown', style: 'z-index: 10000' }

                      - unless user_is_admin?
                        - if registration_is_open
                          %h6.dropdown-header Registration

                          - if current_registration.present?
                            .dropdown-item
                              Status: #{current_registration.status.titleize}

                            = link_to 'Review registration', review_event_registration_path(current_registration), class: 'dropdown-item'

                            - if current_registration.status != 'complete'
                              = link_to 'Pay fee', payment_event_registration_path(current_registration), class: 'dropdown-item'

                            = link_to 'Update Sunday lunch', edit_sunday_lunch_event_registration_path(current_registration.id), class: 'dropdown-item'

                          = link_to 'Update vehicles', edit_user_vehicles_path(current_user), class: 'dropdown-item'

                      - else
                        %span.dropdown-item
                          %strong Admin Menu
                        .dropdown-divider
                        = link_to "Admin Dashboard", admin_admin_dashboard_path, class: 'dropdown-item'
                        = link_to 'Create a registration', new_by_admin_event_registrations_path, class: 'dropdown-item'
                        = link_to 'Current Registrants (default)', admin_admin_dashboard_path, class: 'dropdown-item'
                        = link_to 'Active Users', admin_admin_dashboard_path(user_type: 'active'), class: 'dropdown-item'
                        = link_to 'Vendors', admin_admin_dashboard_path(user_type: 'vendors'), class: 'dropdown-item'
                        = link_to 'Any Registrants', admin_admin_dashboard_path(user_type: 'registrant'), class: 'dropdown-item'
                        = link_to 'All Users', admin_admin_dashboard_path(user_type: 'all_users'), class: 'dropdown-item'
                        = link_to 'Site Testers', admin_admin_dashboard_path(user_type: 'testers'), class: 'dropdown-item'
                        = link_to "Toggle Admin Bar", '#', class: 'dropdown-item toggle_admin_panel'

                      .dropdown-divider
                      = button_to 'Sign Out', destroy_user_session_path, method: :delete, class: 'dropdown-item', data: { turbo: false }
