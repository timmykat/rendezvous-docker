- reg_status = registration.nil? ? 'Unregistered' : registration.status
- previous_step = previous_step(step)
- next_step = next_step(step, reg_status)
.container-fluid.px-0.sticky-top
  .row.no-gutters.justify-content-center
    - unless registration.nil?
      .registration-id{ "data-registration_id" => registration.id}
    .registration-step.vw-100
      %div{ class: "justify-content-center py-3" }
        = "Registration status: #{reg_status.humanize}"
        - if !registration.nil? and no_fee_related_changes
          &ndash; you may only change vehicles or Sunday lunch attendance
      %ul.list-group.list-group-horizontal.d-flex.justify-content-center.align-items-center
        %li.list-group-item.step.prev
          - unless previous_step.nil?
            = "&larr; #{previous_step}".html_safe
        %li.list-group-item.step.current
          = step
        %li.list-group-item.step.next
          - unless next_step.nil?
            = "#{next_step} &rarr;".html_safe
