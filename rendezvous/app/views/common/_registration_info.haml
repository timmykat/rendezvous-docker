.container
  .row.justify-content-center
    .col-md-8.col-12
      .card
        .card-body
          .card-title
            %h3.h4= @registration.user.full_name
          .card-text
            %p
              %label Registration Status - #{@registration.status}
            %p= @registration.user.email
            %p
              #{@registration.user.address1}
              - unless @registration.user.address2.blank?
                %br #{@registration.user.address2}
              %br #{@registration.user.city}, #{@registration.user.state_or_province} #{@registration.user.postal_code}
              #{@registration.user.country_name.upcase}

      .card
        .card-body
          .card-title
            %h3.h4 Attendees
          .card-text
            %table.table
              %thead
                %th Name
                %th Adult, Youth, or Child
                %th Volunteer
              %tbody
                -@registration.attendees.each do |a|
                  %tr
                    %td= a.name
                    %td= a.attendee_age
                    %td #{a.volunteer? ? 'yes' : 'no'}

      .card
        .card-body
          .card-title
            %h3.h4 Special Events
          .card-text
            %ul
              %li
                %h4.h5 Lake George Excursion
                - if @registration.lake_cruise_number > 0
                  %p Number going: #{@registration.lake_cruise_number}
                  %p Total fee: #{number_to_currency(@registration.lake_cruise_fee)}
                - else
                  %p Not going
            %ul
              %li
                %h4.h5 Post-Rendezvous Lunch at Shadow 66
                - if @registration.sunday_lunch_number > 0
                  %p Number going: #{@registration.sunday_lunch_number}
                - else
                  %p Not going

      .card
        .card-body
          .card-title
            %h3.h4 Fees (USD)
          .card-text
            .row
              .col-md-12
                %p
                  %label Registration fee:
                  #{number_to_currency(@registration.registration_fee)}
                  %br
                  %label Lake George Excursion:
                  #{number_to_currency(@registration.lake_cruise_fee)}
                  - if @registration.status != Event::Registration::STATUSES[0]
                    %br
                    %label Donation:
                    - if @registration.donation.blank?
                      (no donation)
                    - else
                      #{number_to_currency(@registration.donation)}
                    %br
                    %br
                      %label Total:
                      #{number_to_currency(@registration.total)}

                    - if (@registration.paid_amount > 0.0)
                      %br
                        %label Paid:
                        #{number_to_currency(@registration.paid_amount)}

                    %strong
                      %label Balance:
                      #{number_to_currency(@registration.balance)}

      .card
        .card-body
          .card-title
            %h3.h4 Vehicle(s) To Be Displayed
          .card-text
            - if registration_complete
              %p
                You can update this by selecting from your name dropdown in the top nav bar.
            - else
              %p
                You can update this after completing payment.

            %table.table
              %thead
                %th Marque
                %th Model
                %th Year
                %th Other info
                %th Judging category
                %th For sale?
              %tbody
                - @registration.vehicles.each do |v|
                  %tr
                    %td= v.marque
                    %td= v.model
                    %td= v.year
                    %td= v.other_info
                    %td= v.judging_category
                    %td= v.for_sale? ? 'Yes' : 'No'

      - if user_is_admin?
        .card
          .card-body
            .card-title
              %h3.h4 Email me my registration info
            .card-text
              = link_to "Send Email", "/admin/event/registrations/#{@registration.id}/send_confirmation_email", class: "btn  btn-info"
