.container
  .row.justify-content-center
    .col-md-8
      .card
        .card-title
          %h1.h3 Vehicle #{@vehicle.id}
        .card-body
          .card-text
            %p
              %strong #{@vehicle.year_marque_model}
            %p Owner: #{@vehicle.user.full_name}
            %p Judging category: #{@vehicle.judging_category}
            - code = @vehicle&.qr_code&.code
            %p Voting code: #{code.present? ? code : '(None)'}
            %p
              Other info:
              #{@vehicle.other_info}
            %p= link_to 'Edit this vehicle', edit_vehicle_path(@vehicle), class: 'btn btn-primary'
