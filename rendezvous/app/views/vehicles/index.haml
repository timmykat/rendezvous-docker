.container
  .row.justify-content-center
    .col-md-8
      .card
        .card-body
          .card-title
            %h1.h3 All Vehicles
          .card-text
            %table
              %thead
                %tr
                  %th
                    Owner
                  %th
                    Vehicle
                  %th
                    Code
                  %th
                    QR Code
              %tbody
                - @vehicles.each do |v|
                  %tr
                    %td= link_to 'Edit', edit_vehicle_path(v)
                    %td #{v.user.full_name}
                    %td #{v.year_marque_model}
                    - code = v&.qr_code&.code
                    - file_path = v.server_qr_file_path
                    - if code && file_path
                      %td= code
                      %td
                        %div{style: 'padding: 5px 20px'}
                          = image_tag qr_code_url(v.qr_code.code), {style: 'width: 60px; height: 60px;'}
                    - else
                      %td{ colspan: '2' } (no image yet)
