.container-fluid
  .row
    .col-12
      %h1 Administrative Info

  .row
    .col-12
      #tabbed
        %ul
          %li= link_to 'Registrations', '#tabbed-1'
          %li= link_to 'Vehicles', '#tabbed-2'
          %li= link_to 'Volunteer List', '#tabbed-3'
          %li= link_to 'Summary'.html_safe, '#tabbed-5'
        #tabbed-1
          .row 
            .col-md-4
              = form_with url: admin_dashboard_path, method: :get do |f|
                - options = options_for_select( (Event::Registration.distinct.pluck(:year) + [Date.current.year.to_s]).uniq.sort.reverse, @year )
                .form-group
                  = f.label :year
                  = f.select :year, options, {}, { class:  'form-select' }
                .form-group
                  = f.submit 'Go', class:  "btn  btn-primary"
          
          %h2= "Registrations for #{@year}"
          %p Number of registrations: #{@reg_count}

          %table#registration-table.table.tablesorter.striped
            %thead
              %tr

                %th.tablesorter-header.filter-false.text-center Actions
                %th.tablesorter-header.filter-false.text-center Status
                %th.tablesorter-header.filter-parsed{'data-placeholder' => 'Search'}  Name
                %th.tablesorter-header.filter-false.text-center Adults, Youths, Children
                %th.tablesorter-header.filter-false.text-center Fee
                %th.tablesorter-header.filter-false.text-center Donation
                %th.tablesorter-header.filter-false.text-center Total
                %th.tablesorter-header.filter-false.text-center Paid
                %th.tablesorter-header.filter-false.text-center Balance
            %tbody
              - @event_registrations.each do |reg|
                %tr.text-center
                  %td.text-left
                    %ul.list-unstyled
                      %li= link_to 'View', event_registration_path(reg)
                      %li= link_to 'Edit', edit_event_registration_path(reg)
                      - if reg.status != 'complete'
                        %li= link_to 'Review', review_event_registration_path(reg)
                        %li= link_to 'Payment', payment_event_registration_path(reg)
                      %li= link_to 'Cancel', event_cancel_registration_path(reg), data: { confirm: "Sure?" }
                      %li= link_to 'DELETE', event_destroy_registration_path(reg), method: :delete, data: { confirm: "Permanent?" }
                          
                  %td= reg.status
                  %td.text-left
                    - if reg.user
                      = link_to reg.user.last_name_first, user_path(reg.user)
                    - else 
                      *** Missing User (ID: #{reg.id})
                  
                  %td.text-left= format_attendee_counts(reg)
                  %td.text-right= number_to_currency(reg.registration_fee)
                  %td.text-right= number_to_currency(reg.donation)
                  %td.text-right= number_to_currency(reg.total)
                  %td.text-right= number_to_currency(reg.paid_amount)
                  
                  -# Use the balance column directly
                  - if reg.balance > 0
                    %td.text-center.has-balance= number_to_currency(reg.balance)
                  - elsif reg.balance < 0
                    %td.text-center.owed (#{number_to_currency(reg.balance.abs)})
                  - else 
                    %td.text-center $0.00
        #tabbed-2
          %h2 Summary
          .card-text
            - if @data
              -# Remove .count here because @data[:citroens] is already an Integer
              %p Number of Citroens: #{@data[:citroens]}
              %p Number of non-Citroens: #{@data[:non_citroens]}
            
            - if @vehicles
              -# Keep .count here because @vehicles is a Collection
              %p Total Vehicles: #{@vehicles.count}

          %table.table
            %thead
              %tr
                %th Judging Category
                %th Model
                %th Year
                %th Marque
                %th Other Info
                %th Registrant
            %tbody
              - unless @vehicles
                %p No vehicles yet.
              - else
                - @vehicles.each do |vehicle|
                  %tr
                    %td= vehicle.judging_category
                    %td= vehicle.model
                    %td= vehicle.year
                    %td= vehicle.marque
                    %td
                      %p= vehicle.other_info
                    %td= vehicle.user.full_name
        #tabbed-3
          .card 
            .card-body 
              .card-title
                %h2 Volunteer List
              .card-text
                - if @volunteers
                  %p Total volunteers: #{@volunteers.size}

          %table.table
            %thead
              %tr
                %th Name
                %th Email (of registered user)
              %tbody
                - if @data
                  - @volunteers.each do |volunteer|
                    %tr
                      %td= volunteer[:name]
                      %td= volunteer[:email]
        #tabbed-5
          .card
            .card-body
              .card-title
                %h2 Summary for #{@year}
              .card-text
                .row
                  .col-md-12
            

            -# .row.justify-content-center
            -#   .col-md-8.col-12
            -#     .card
            -#       .card-body
            -#         .card-title
            -#           %h3 Annual Question Responses 
            -#         .card-body 
            -#           %p
            -#             %strong #{@annual_question.question}
            -#           %p Responses:
            -#           %ul
            -#             - @annual_responses.each do |answer, number|
            -#               %li #{number} | #{answer}
            .row
              .col-md-6.col-12
                .card
                  .card-body
                    .card-title
                      %h3 Financials
                    .card-text
                      - if @data
                        %table.table
                          %tbody
                            %tr
                              %td
                                %em  Registration fees
                              %td.text-right= number_to_currency(@data[:financials][:registration_fees])
                            %tr
                              %td
                                %em  Donations
                              %td.text-right= number_to_currency(@data[:financials][:donations])
                            %tr
                              %td
                                %em  Paid
                              %td.text-right= number_to_currency(@data[:financials][:paid])
                            %tr
                              %td
                                %em  Due
                              %td.text-right= number_to_currency(@data[:financials][:due])
                            %tr
                              %td
                                %em  Total
                              %td.text-right= number_to_currency(@data[:financials][:total])
                      %p
                        Square account:
                        = link_to '<i class="fa fa-bank"></i>'.html_safe, "https://app.squareup.com", target:  '_blank'

              .col-md-6.col-12
                .card
                  .card-body
                    .card-title
                      %h3 The Numbers
                    .card-text
                      - if @data
                        %table.table
                          %tbody
                            %tr
                              %td
                                %em  Registrations
                              %td.text-right= @data[:registrants].count
                            %tr
                              %td
                                %em  Attendees
                              %td.text-right
                                Adults: #{@data[:adult]}
                                %br
                                  Youths:   #{@data[:youth]}
                                %br
                                  Kids:   #{@data[:child]}
                            %tr
                              %td
                                %em  Volunteers
                              %td.text-right= @volunteers.length
                            %tr
                              %td
                                %em  Vehicles
                              %td.text-right= @vehicles&.count || 0
                            %tr
                              %td{ colspan:  2 }
                                %p
                                  %em  Newbies
                                %p
                                  - @data[:newbies].each do |newbie|
                                    = newbie.full_name
                                    %br


                          