- @registrations.each_slice(6) do |page_regs|
  .registration-labels
    .wrapper-page
      .wrapper
        - page_regs.each do |r|
          .label-wrapper
            .label
              .content
                .info
                  .name #{r.user.last_name}
                  .people
                    Citronistas: #{r.number_of_people}
                    %ul{style: 'list-style: none;'}
                      - r.attendees.each do |a|
                        %li
                          #{a.name}
                          - if a.volunteer?
                            (volunteer)
                  .fee
                    - if r.balance > 0.0
                      Due: #{number_to_currency(r.balance)}
                    - else
                      Paid - thank you!

                  - if r.donation > 0
                    .thank-you.donation You donated - thank you!

              .ident
                .info
                  .title Citroën Rendezvous 2026
                  .loc Saratoga Springs, NY
                .logo
                  = image_tag 'R26-fiftieth.png', alt: 'Citroen Rendezvous'
