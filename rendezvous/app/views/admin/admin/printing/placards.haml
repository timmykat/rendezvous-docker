- @vehicles.each do |v|
  .placard
    %header
      .logo
        %img{ src: asset_url('R26-fiftieth-b+w.png')}
      .text
        50th Citroen Rendezvous &ndash; #{Date.current.year}

    .datum
      %span.label Vehicle:
      %span.value #{v.year_marque_model}

    .datum
      %span.label Owner:
      %span.value #{v.user.full_name}

    .datum
      %span.label Category:
      %span.value #{v.judging_category}

    .qr-code-id
      %span.image
        = image_tag qr_code_url(v.qr_code.code)
      %span People's Choice ID
      %span.code #{v.qr_code.code}
