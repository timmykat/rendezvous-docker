.container
  .row.justify-content-center
    .col-md-8.col-12
      .card
        .card-body
          .card-title
            %h2 Create a registration
          .card-text
            #registration-form.edit_registration
              = simple_form_for @registration, url: create_by_admin_event_registrations_path, method: :post do |f|
                = render partial: 'admin_fields', locals: { f: f, reg: @registration, user: @user }
                .row
                  .col-12
                    .form-group
                      = f.submit 'Create', class:  "btn btn-primary"
