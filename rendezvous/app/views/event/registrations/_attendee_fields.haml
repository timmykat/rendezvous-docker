- fees = event_fees_for_period
.nested-fields
  .row
    .col-md-12
      .card.attendee{ data: { fee: fees[:adult] } }
        .card-body
          .card-title
            .registrant.attendee-type
              You
            .guest.attendee-type 
              Guest
          .card-text
            .form-group
              = f.input :name, label:  'Name (for name tag)', input_html:  { placeholder:  'Name *' }
            .form-group
              = f.input :attendee_age, label:  '', collection:  [[" Adult (16+): $#{fees[:adult]}", 'adult'], [" Youth (5-15): $#{fees[:youth]}", 'youth'], [' Child, 0-5 (free)', 'child']], as:  :radio_buttons, item_label_class:  'form-check-label ps-2'
            .form-group
              = f.input :volunteer, inline_label:  "Would like to volunteer (<a href='#' data-toggle='modal', data-target='#volunteer-info'>What volunteer tasks are there?</a>)".html_safe
            .form-group 

            - unless no_fee_related_changes    
            .row
              .col-md-12
                .remove_association_action
                  = link_to_remove_association "#{icon(:remove_person)}".html_safe, f, class:  'btn btn-danger '
                  Remove this person
