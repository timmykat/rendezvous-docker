%special-events
  .card
    .card-body
      .card-title
        %h2.h3 Special Events
      .card-text
        .card{ data: { event: 'cruise', price: lake_cruise_price } }
          .card-body
            .card-title
              %h3.h4 Lake George Cruise
            .card-text
              .form-group
                = f.input :lake_cruise_number, as: :select, collection: (0..lake_cruise_max),
                  label: "Number of people for Lake George cruise",
                  input_html: { class: 'lake-cruise form-control short-field' }
                = f.input :lake_cruise_fee, input_html: { readonly: true, class: 'lake-cruise-fee short-field' }

        .card{ data: { event: 'post-rendezvous-lunch' } }
          .card-body
            .card-title
              %h3.h4 Post-Rendezvous Lunch
            .card-text
              .form-group
                / Use Simple Form's built-in label for better accessibility and alignment
                = f.input :sunday_lunch_number, as: :select, collection: (0..sunday_lunch_max),
                          label: "Number of people for Sunday lunch",
                          input_html: { class: 'form-control short-field' }
        .form-group
          - reg_fee = @event_registration.registration_fee
          - cruise_fee = @event_registration.lake_cruise_fee || 0.0
          = f.input :registration_fee, as: :hidden
          %label Total fee including cruise
          = text_field_tag :display_total, number_with_precision(reg_fee + cruise_fee, precision: 2), readonly: true, class: 'form-control display-total short-field'
