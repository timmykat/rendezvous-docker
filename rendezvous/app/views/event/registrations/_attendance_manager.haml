%attendance-manager{ data: { fee_structure: fee_structure.to_json.html_safe }}
  %h2.h3 Registration Information
  %h3.h4 Attendees
  %p.hint (Adults are 16+, youths are 5-15, and children are under 5)
  - if current_user.admin?
    .form-group
      = f.input :fee_period, id: 'registration_fee_period', as: :select, collection: Event::Registration.fee_periods
  - else
    = f.input :fee_period, readonly: true,  id: 'registration_fee_period'
  .row
    .col-12
      #attendees.items
        = f.simple_fields_for :attendees do |a|
          = render partial:  'attendee_fields', locals:  { f:  a }

      - unless no_fee_related_changes
        .links
          = link_to_add_association "#{icon(:add_person)}".html_safe, f, :attendees, class:  'btn btn-primary '
          Add a guest
      %br
      %br
  .row
    .col-md-4
      .form-group
        %label
          Total adults:
          = f.input_field :number_of_adults, readonly:  true
    .col-md-4
      .form-group
        %label
          Total youths:
          = f.input_field :number_of_youths, readonly:  true
    .col-md-4
      .form-group
        %label
          Total children:
          = f.input_field :number_of_children, readonly:  true

  .row
    .col-12
      %p.amount.form-group
        = f.input :registration_fee, input_html: { label: 'Attendee fee total:', class: 'attendee-total fixed-2', data: { summary_source: true } }

  = f.input_field :year, as:  :hidden, value:  Time.new.year
